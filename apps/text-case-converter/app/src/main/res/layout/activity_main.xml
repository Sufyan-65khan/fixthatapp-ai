<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_primary"
        app:title="@string/app_name"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/textInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/code_bg"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:hint="Type or paste text here..."
                android:inputType="textMultiLine"
                android:minHeight="200dp"
                android:padding="12dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Row 1: UPPERCASE, lowercase -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUppercase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="UPPERCASE"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLowercase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="lowercase"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />
            </LinearLayout>

            <!-- Row 2: Title Case, Sentence case -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTitleCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="Title Case"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSentenceCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="Sentence case"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />
            </LinearLayout>

            <!-- Row 3: camelCase, PascalCase -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamelCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="camelCase"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPascalCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="PascalCase"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />
            </LinearLayout>

            <!-- Row 4: snake_case, kebab-case -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSnakeCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="snake_case"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKebabCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="kebab-case"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />
            </LinearLayout>

            <!-- Row 5: CONSTANT_CASE, dot.case -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConstantCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="CONSTANT_CASE"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDotCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="dot.case"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />
            </LinearLayout>

            <!-- Row 6: Toggle cAsE, Reverse -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleCase"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="Toggle cAsE"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReverse"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="Reverse"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_primary" />
            </LinearLayout>

            <!-- Copy and Clear buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopy"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="Copy" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClear"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="Clear" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:adSize="BANNER"
        app:adUnitId="ca-app-pub-3940256099942544/6300978111" />

</LinearLayout>
